<?xml version="1.0"?>
<robot name="simple_knee_arm">

  <!-- ********* СТОЙКА (невидимая) ********* -->
  <link name="world"/>

  <!-- ********* БАЗА ********* -->
  <link name="base_link">
    <visual>
      <geometry>
        <box size="0.2 0.2 0.1"/>
      </geometry>
      <material name="grey">
        <color rgba="0.5 0.5 0.5 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <box size="0.2 0.2 0.1"/>
      </geometry>
    </collision>
    <inertial>
      <mass value="5"/>
      <inertia ixx="0.1" ixy="0.0" ixz="0.0" iyy="0.1" iyz="0.0" izz="0.1"/>
      <origin xyz="0 0 0.05"/>
    </inertial>
  </link>

  <!-- ********* ПЛЕЧО (верхняя часть) ********* -->
  <link name="upper_arm">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.4"/>
      </geometry>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <material name="blue">
        <color rgba="0 0 1 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.4"/>
      </geometry>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      <origin xyz="0 0 0.2"/>
    </inertial>
  </link>

  <!-- ********* ПРЕДПЛЕЧЬЕ (нижняя часть) ********* -->
  <link name="forearm">
    <visual>
      <geometry>
        <cylinder radius="0.03" length="0.4"/>
      </geometry>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
      <material name="red">
        <color rgba="1 0 0 1"/>
      </material>
    </visual>
    <collision>
      <geometry>
        <cylinder radius="0.03" length="0.4"/>
      </geometry>
      <origin xyz="0 0 0.2" rpy="0 0 0"/>
    </collision>
    <inertial>
      <mass value="1"/>
      <inertia ixx="0.01" ixy="0.0" ixz="0.0" iyy="0.01" iyz="0.0" izz="0.01"/>
      <origin xyz="0 0 0.2"/>
    </inertial>
  </link>

  <!-- ********* СОЕДИНЕНИЯ ********* -->

  <!-- фиксация базы к мировому звену -->
  <joint name="world_to_base" type="fixed">
    <parent link="world"/>
    <child link="base_link"/>
    <origin xyz="0 0 0.05" rpy="0 0 0"/>
  </joint>

  <!-- плечо жёстко срощено с базой (можно и revolute, но по заданию только одно колено) -->
  <joint name="base_to_upper_arm" type="fixed">
    <parent link="base_link"/>
    <child link="upper_arm"/>
    <origin xyz="0 0 0.1" rpy="0 0 0"/>
  </joint>

  <!-- коленный шарнир (вращение вокруг Y) -->
  <joint name="knee_joint" type="revolute">
    <parent link="upper_arm"/>
    <child link="forearm"/>
    <origin xyz="0 0 0.4" rpy="0 0 0"/>
    <axis xyz="0 1 0"/>
    <limit lower="-1.57" upper="1.57" effort="100" velocity="1.0"/>
    <dynamics damping="0.5" friction="0.1"/> <!-- небольшая вязкость -->
  </joint>


<gazebo>
  <plugin filename="gz-sim-joint-position-controller-system" name="gz::sim::systems::JointPositionController">
    <joint_name>knee_joint</joint_name>
    <topic>/model/simple_knee_arm/joint/knee_joint/cmd_pos</topic>
    <p_gain>10.0</p_gain>
    <i_gain>0.1</i_gain>
    <d_gain>1.0</d_gain>
    <initial_position>0.0</initial_position>
    <use_velocity_commands>false</use_velocity_commands>
  </plugin>
</gazebo>



</robot>