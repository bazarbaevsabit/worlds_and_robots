<?xml version="1.0"?>
<robot name="vehicle_blue">

    <!-- ОПРЕДЕЛЕНИЕ ЦВЕТОВ -->
    <material name="blue"><color rgba="0 0 1 1"/></material>
    <material name="red"><color rgba="1 0 0 1"/></material>
    <material name="green"><color rgba="0 1 0 1"/></material>
     <material name="black"><color rgba="0 0 0 1"/></material> 
    <!-- КОРПУС -->
    <link name="chassis">
        <visual>
            <geometry>
                <box size="2.0 1.0 0.5"/>
            </geometry>
            <material name="blue"/>
        </visual>
    </link>

    <!-- ЛИДАР -->
    <link name="vehicle_blue/chassis/gpu_lidar">
        <visual>
            <geometry>
                <cylinder radius="0.1" length="0.1"/>
            </geometry>
            <material name="red"/>
        </visual>
    </link>

    <!-- ЛЕВОЕ КОЛЕСО -->
    <link name="left_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="1.5707 0 0"/>
            <geometry>
                <cylinder radius="0.4" length="0.2"/>
            </geometry>
            <material name="red"/>
        </visual>
    </link>

    <!-- ПРАВОЕ КОЛЕСО -->
    <link name="right_wheel">
        <visual>
            <origin xyz="0 0 0" rpy="1.5707 0 0"/>
            <geometry>
                <cylinder radius="0.4" length="0.2"/>
            </geometry>
            <material name="red"/>
        </visual>
    </link>

    <!-- ПОДДЕРЖИВАЮЩИЙ РОЛИК -->
    <link name="caster">
        <visual>
            <geometry>
                <sphere radius="0.2"/>
            </geometry>
            <material name="green"/>
        </visual>
    </link>
    <!-- КАМЕРА -->
    <link name="camera_link">
        <visual>
            <geometry>
                <box size="0.15 0.05 0.05"/>
            </geometry>
            <material name="black"/>
        </visual>
    </link>
    <!-- СОЕДИНЕНИЯ (JOINTS) -->
    <joint name="left_wheel_joint" type="continuous">
        <parent link="chassis"/>
        <child link="left_wheel"/>
        <origin xyz="-0.5 0.6 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="right_wheel_joint" type="continuous">
        <parent link="chassis"/>
        <child link="right_wheel"/>
        <origin xyz="-0.5 -0.6 0" rpy="0 0 0"/>
        <axis xyz="0 1 0"/>
    </joint>

    <joint name="caster_wheel_joint" type="fixed">
        <parent link="chassis"/>
        <child link="caster"/>
        <origin xyz="0.8 0 -0.2" rpy="0 0 0"/>
    </joint>

    <joint name="lidar_joint" type="fixed">
        <parent link="chassis"/>
        <child link="vehicle_blue/chassis/gpu_lidar"/>
        <origin xyz="0.8 0 0.35" rpy="0 0 0"/>
    </joint>
        <joint name="camera_joint" type="fixed">
        <parent link="chassis"/>
        <child link="camera_link"/>
        <origin xyz="1.0 0 0.25" rpy="0 0 0"/>
    </joint>
     <gazebo reference="camera_link">
        <sensor name="camera" type="camera">
            <always_on>true</always_on>
            <update_rate>30.0</update_rate>
            <visualize>true</visualize>
            <camera>
                <horizontal_fov>1.047</horizontal_fov>
                <image>
                    <width>640</width>
                    <height>480</height>
                    <format>R8G8B8</format>
                </image>
                <clip>
                    <near>0.1</near>
                    <far>100</far>
                </clip>
            </camera>
            <plugin name="gz_ros_camera" filename="libgz-sim-ros-camera-system.so">
                <ros>
                    <namespace>/</namespace>
                    <argument>--ros-args --remap __node:=camera_node</argument>
                </ros>
                <camera_name>camera</camera_name>
                <image_topic_name>/camera/image_raw</image_topic_name>
                <camera_info_topic_name>/camera/camera_info</camera_info_topic_name>
                <frame_name>camera_link</frame_name>
            </plugin>
        </sensor>
    </gazebo>

</robot>
